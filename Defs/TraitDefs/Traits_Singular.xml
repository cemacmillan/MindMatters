                    <WorkSpeedGlobal>0.2</WorkSpeedGlobal>
                    <MoveSpeed>0.05</MoveSpeed>
                </statOffsets>
            </li>
        </degreeDatas>
    </TraitDef>
    <TraitDef>
        <defName>Outgoing</defName>
