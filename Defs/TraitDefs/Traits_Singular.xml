    <TraitDef>
        <defName>Organized</defName>
        <commonality>0.5</commonality>
        <degreeDatas>
            <li>
                <degree>1</degree>
                <label>organized</label>
                <description>[PAWN_nameDef] is meticulous and structured, always maintaining order in everything [PAWN_pronoun] does. This means [PAWN_pronoun] is efficient in [PAWN_possessive] work and maintains a good mood as long as things are in order.</description>
