            <li>
                <degree>0</degree>
                <label>outgoing</label>
                <description>[PAWN_nameDef] enjoys socializing and dislikes being alone. [PAWN_pronoun] gets a mood bonus when socializing and a mood debuff when isolated.</description>
                <statOffsets>
                    <SocialImpact>0.2</SocialImpact>
                </statOffsets>
                <skillGains>
            <li>
