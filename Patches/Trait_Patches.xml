<Patch>
	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationTest">
			  <xpath>Defs/TraitDef[defName="Nudist"]/conflictingTraits</xpath>
			  <success>Invert</success>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/TraitDef[defname="Nudist"]</xpath>
				<value>
					<conflictingTraits>
						<li>Prude</li>
					</conflictingTraits>
				</value>
			</li>
		</operations>
	</Operation>
	
	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationTest">
			  <xpath>Defs/TraitDef[defName="Bloodlust"]/conflictingTraits</xpath>
			  <success>Invert</success>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/TraitDef[defname="Bloodlust"]</xpath>
				<value>
					<conflictingTraits>
						<li>TenderHearted</li>
						<li>Desensitized</li>
					</conflictingTraits>
				</value>
			</li>
		</operations>
	</Operation>
	
	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationTest">
			  <xpath>*/TraitDef[defName="Psychopath"]/conflictingTraits</xpath>
			  <success>Invert</success>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>*/TraitDef[defname="Psychopath"]</xpath>
				<value>
					<conflictingTraits>
						<li>TenderHearted</li>
						<li>Desensitized</li>
						<li>OpenMinded</li>
					</conflictingTraits>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>